[org.gnome.desktop.app-folders]
folder-children=[]

[org.gnome.shell]
favorite-apps=[]

[org.gnome.desktop.app-folders]
folder-children=[]

[org.gnome.desktop.background]
picture-uri='file:///usr/share/backgrounds/evenkite/evenkite_light.png'
picture-uri-dark='file:///usr/share/backgrounds/evenkite/evenkite_dark.png'
picture-options='zoom'

[org.gnome.desktop.interface]
gtk-theme = "adw-gtk3"

[org.gnome.Ptyxis]
profile-uuids=['fishshell-0000-0000-0000-000000000000']
default-profile-uuid='fishshell-0000-0000-0000-000000000000'

[org/gnome/Ptyxis/Profiles/fishshell-0000-0000-0000-000000000000]
use-custom-command=true
custom-command='/usr/bin/fish'